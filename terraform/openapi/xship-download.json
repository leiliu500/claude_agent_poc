{
  "openapi": "3.0.0",
  "info": {
    "title": "XShipDownload Action Group",
    "version": "1.0.0",
    "description": "Run XShip activity download use cases."
  },
  "paths": {
    "/run": {
      "post": {
        "operationId": "runXShipDownloadUseCase",
        "summary": "Execute an XShipDownload use case and return its rows + metadata.",
        "description": "Runs one XShipDownload use case (activity by ABA/rollup/zone or criteria-by-period).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["useCase"],
                "properties": {
                  "useCase": {
                    "type": "string",
                    "description": "The XShipDownload use case to execute.",
                    "enum": [
                      "xshipDownloadActivityAba",
                      "xshipDownloadActivityAbaRollup",
                      "xshipDownloadActivityZone",
                      "xshipDownloadCriteriaPeriod"
                    ]
                  },
                  "params": {
                    "type": "object",
                    "description": "Extracted parameters.",
                    "properties": {
                      "period": { "type": "string", "description": "Reporting period, e.g. 2026-Q2." },
                      "abaNumber": { "type": "string", "description": "9-digit ABA routing number." },
                      "zone": { "type": "string", "description": "Activity zone code." }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dispatch result for the XShipDownload use case.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string" },
                    "useCase": { "type": "string" },
                    "status": { "type": "string" },
                    "data": { "type": "array", "items": { "type": "object" } },
                    "meta": { "type": "object" },
                    "latencyMs": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
